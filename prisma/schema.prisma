generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Plan {
  FREE
  STARTER
  GROWTH
  PRO
  AGENCY
}

enum LedgerType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  BANK
  UPI
  CARD
}

enum CouponType {
  PERCENTAGE
  FIXED
}

// ==================== AUTH & TENANCY ====================

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  password             String?
  phone                String?
  role                 Role      @default(MEMBER)
  businessId           String?
  business             Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  emailVerified        DateTime?
  avatar               String?
  isActive             Boolean   @default(true)
  lastLoginAt          DateTime?
  lastLoginIp          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // 2FA
  twoFactorSecret      String?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorBackupCodes String?

  // Password Reset
  resetToken         String?
  resetTokenExpiry   DateTime?
  emailVerifyToken   String?
  emailVerifyExpiry  DateTime?

  // Relations
  notifications      Notification[]
  themePref          ThemePreference?
  aiContents         AIContent[]
  activities         Activity[]
  auditLogs          AuditLog[]

  @@index([businessId])
  @@index([email])
  @@index([role])
}

model Business {
  id              String   @id @default(cuid())
  name            String
  type            String
  phone           String?
  email           String?
  city            String?
  state           String?
  country         String   @default("India")
  address         String?
  website         String?
  logoUrl         String?
  brandColors     Json?
  timezone        String   @default("Asia/Kolkata")

  // Limits
  contactsLimit   Int      @default(500)
  messagesLimit   Int      @default(1000)
  usersLimit      Int      @default(1)

  // Subscription
  plan            Plan     @default(FREE)
  planStartedAt   DateTime?
  planExpiresAt   DateTime?
  razorpaySubId   String?
  razorpayOrderId String?

  // WhatsApp
  wabaId          String?
  waPhoneNumberId String?
  waAccessToken   String?
  waWebhookSecret String?
  waPhoneNumber   String?

  // Social Media
  fbPageId            String?
  fbAccessToken       String?
  igUserId            String?
  igAccessToken       String?
  linkedinPageId      String?
  linkedinAccessToken String?
  twitterUserId       String?
  twitterAccessToken  String?

  // Google Business Profile
  gbpAccessToken  String?
  gbpAccountId    String?
  gbpLocationId   String?

  // Auto Reply
  autoReplyEnabled Boolean   @default(false)
  autoReplyMessage String?
  businessHours    Json?

  isActive        Boolean  @default(true)

  // AI Credits
  aiCreditsUsed      Int @default(0)
  aiCreditsLimit     Int @default(100)
  aiCreditsPurchased Int @default(0)

  // Relations
  users               User[]
  contacts            Contact[]
  ledgerEntries       LedgerEntry[]
  coupons             Coupon[]
  pipelines           Pipeline[]
  campaigns           Campaign[]
  appointments        Appointment[]
  documents           Document[]
  products            Product[]
  posts               Post[]
  reviews             Review[]
  integrations        Integration[]
  activities          Activity[]
  wingsStore          WingsStore[]
  eCommerceStore      ECommerceStore?
  posterTemplates     PosterTemplate[]
  whiteLabel          WhiteLabel?
  messageTemplates    MessageTemplate[]
  documentTemplates   DocumentTemplate[]
  autopilotSettings   AutopilotSettings?
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  automationRules     AutomationRule[]
  workflowRuns        WorkflowRun[]
  invoices            Invoice[]
  leadScores          LeadScore[]
  webhooks            Webhook[]
  apiKeys             ApiKey[]
  chatbotFlows        ChatbotFlow[]
  scheduledMessages   ScheduledMessage[]
  autoReplies         AutoReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plan])
}

model Subscription {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  plan     Plan
  status   String
  startDate DateTime
  endDate   DateTime?

  razorpaySubscriptionId String?
  razorpayOrderId        String?
  razorpayPaymentId      String?

  amount   Int
  currency String @default("INR")
  interval String

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  cancelledBy        String?

  metadata        Json?
  paymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([status])
}

// ==================== CONTACTS & CRM ====================

model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  phone       String?
  email       String?
  company     String?
  title       String?
  designation String?
  city        String?
  state       String?

  source   String  @default("manual")
  sourceId String?

  pipelineId String?
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stageId    String?
  stageName  String?

  tags         String[] @default([])
  customFields Json?
  metadata     Json?

  dealValue Float   @default(0)
  dealStage String?

  whatsappOptIn   Boolean   @default(false)
  whatsappBlocked Boolean   @default(false)
  waProfilePic    String?
  waLastMessageAt DateTime?
  lastMessageAt   DateTime?
  lastActivity    DateTime?

  status     String  @default("active")
  stage      String?
  assignedTo String?

  emailOptIn Boolean @default(false)

  // Relations
  activities        Activity[]
  appointments      Appointment[]
  documents         Document[]
  messages          Message[]
  orders            Order[]
  leadScores        LeadScore[]
  ledgerEntries     LedgerEntry[]
  scheduledMessages ScheduledMessage[]
  dripQueueItems    DripQueue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([source])
  @@index([tags])
  @@index([status])
}

model Pipeline {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name      String
  description String?
  stages    Stage[]
  contacts  Contact[]
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

model Stage {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name  String
  order Int
  color String?

  @@index([pipelineId])
}

model Activity {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  type        String
  title       String
  description String?
  content     String?
  metadata    Json?

  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  priority    String    @default("medium")

  dealValue Float?
  stageFrom String?
  stageTo   String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([contactId])
  @@index([type])
  @@index([createdById])
}

// ==================== WHATSAPP MESSAGING ====================

model Message {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  businessId String?

  waMessageId String?
  direction   String
  type        String @default("text")
  content     String?
  mediaUrl    String?
  mediaType   String?
  mediaSize   Int?
  mediaName   String?

  templateName     String?
  templateLanguage String?
  templateParams   Json?

  status          String    @default("pending")
  statusUpdatedAt DateTime?
  errorCode       String?
  errorMessage    String?

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  interactiveType String?
  metadata        Json?

  replyToMessageId String?
  replyContext     Json?

  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([status])
  @@index([createdAt])
  @@index([businessId])
}

model MessageTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  language String @default("en")
  category String @default("UTILITY")
  components Json

  status       String  @default("PENDING")
  waTemplateId String?
  waStatus     String?

  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([businessId, name])
}

// ==================== CAMPAIGNS ====================

model Campaign {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name   String
  type   String
  status String @default("draft")

  segmentId     String?
  filters       Json?
  contactIds    String[] @default([])
  targetTags    String[] @default([])
  targetFilters Json?
  targetCount   Int      @default(0)

  templateId   String?
  templateName String?
  templateVars Json?
  content      Json
  dripSteps    Json?

  scheduledAt DateTime?
  startedAt   DateTime?
  sentAt      DateTime?
  completedAt DateTime?

  totalContacts  Int @default(0)
  totalSent      Int @default(0)
  totalDelivered Int @default(0)
  totalRead      Int @default(0)
  totalReplied   Int @default(0)
  totalFailed    Int @default(0)

  messages    Message[]
  dripQueueItems DripQueue[]

  errors Json[] @default([])

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
}

model DripQueue {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  businessId String?

  step      Int      @default(0)
  stepIndex Int      @default(0)
  stepData  Json?
  sendAt    DateTime
  status    String   @default("pending")
  sentAt    DateTime?
  error     String?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([status])
  @@index([sendAt])
}

// ==================== APPOINTMENTS ====================

model Appointment {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  title       String
  description String?
  service     String?
  startTime   DateTime
  endTime     DateTime
  status      String @default("pending")

  location    String?
  isOnline    Boolean @default(false)
  meetingLink String?

  reminderSent Boolean @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([contactId])
  @@index([startTime])
}

// ==================== E-COMMERCE ====================

model Product {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name           String
  description    String?
  price          Float
  compareAtPrice Float?
  sku            String?
  barcode        String?

  quantity       Int     @default(0)
  trackInventory Boolean @default(true)

  images    String[] @default([])
  mainImage String?

  category String?
  tags     String[] @default([])

  isActive Boolean @default(true)
  status   String  @default("active")

  variants ProductVariant[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name     String
  options  Json
  price    Float?
  sku      String?
  quantity Int     @default(0)

  @@index([productId])
}

model Order {
  id         String @id @default(cuid())
  businessId String

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: SetNull)

  orderNumber   String @unique
  status        String @default("pending")
  paymentStatus String @default("pending")

  subtotal       Float
  taxAmount      Float @default(0)
  shippingAmount Float @default(0)
  discountAmount Float @default(0)
  total          Float

  items OrderItem[]

  shippingAddress Json?

  gateway     String?
  gatewayData Json?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([contactId])
  @@index([orderNumber])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId String?

  name     String
  quantity Int
  price    Float
  total    Float

  @@index([orderId])
}

// ==================== LEDGER ====================

model LedgerEntry {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  date        DateTime @default(now())
  type        LedgerType
  category    String
  description String
  amount      Float

  paymentMethod PaymentMethod?
  referenceNo  String?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([date])
  @@index([type])
  @@index([category])
}

// ==================== COUPONS ====================

model Coupon {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  code  String
  type  CouponType
  value Float

  minOrder Float   @default(0)
  maxUses  Int?
  usedCount Int    @default(0)

  active    Boolean  @default(true)
  startsAt  DateTime @default(now())
  expiresAt DateTime?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId])
  @@index([active])
}

// ==================== DOCUMENTS ====================

model Document {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name           String
  type           String
  templateId     String?
  documentNumber String?

  content Json
  html    String?
  pdfUrl  String?

  status             String    @default("draft")
  sentVia            String[]  @default([])
  publicLink         String?
  publicLinkExpiry   DateTime?

  clientName  String?
  clientPhone String?
  clientEmail String?
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  amount Float?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model DocumentTemplate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  type        String
  description String?

  header  String?
  footer  String?
  content String
  css     String?

  variables Json @default("[]")

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
}

// ==================== SOCIAL MEDIA ====================

model Post {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  content   String
  mediaUrls String[] @default([])
  link      String?

  platforms String[]
  status    String @default("draft")

  scheduledAt  DateTime?
  publishedAt  DateTime?
  publishedIds Json?

  stats Json?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
}

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  platform   String
  externalId String?

  reviewerName  String
  reviewerPhone String?
  reviewerEmail String?

  rating Int      @default(5)
  text   String?
  images String[] @default([])

  replyText   String?
  replyStatus String?
  repliedAt   DateTime?
  repliedById String?

  isPublished Boolean @default(true)
  isFeatured  Boolean @default(false)
  isRead      Boolean @default(false)

  reviewDate DateTime?
  createdAt  DateTime  @default(now())

  @@index([businessId])
  @@index([platform])
}

// ==================== INTEGRATIONS ====================

model Integration {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  type String
  name String

  config Json

  isActive   Boolean   @default(true)
  lastSyncAt DateTime?
  lastError  String?

  webhookUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, type])
  @@index([businessId])
}

// ==================== AI CONTENT ====================

model AIContent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String

  prompt String
  result String

  model      String
  tokensUsed Int

  isFavorite Boolean @default(false)
  rating     Int?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

// ==================== AUTOMATION ====================

model AutomationRule {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean @default(true)

  trigger Json
  actions Json[]

  runCount  Int       @default(0)
  lastRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([isActive])
}

model WorkflowRun {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  ruleId String?
  status String @default("running")

  triggerData Json
  actions     Json[]

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([businessId])
  @@index([status])
}

// ==================== WINGS STORE ====================

model WingsStore {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name     String
  type     String
  category String

  url       String
  thumbnail String?
  size      Int?
  mimeType  String?

  tags     String[] @default([])
  metadata Json?

  isGenerated Boolean @default(false)
  prompt      String?

  createdAt DateTime @default(now())

  @@index([businessId])
}

// ==================== AUTOPILOT ====================

model AutopilotSettings {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  isEnabled  Boolean @default(false)
  replyDelay Int     @default(5)

  welcomeMessage  String?
  welcomeEnabled  Boolean @default(false)

  followUpEnabled Boolean @default(false)
  followUpDelay   Int     @default(1440)
  followUpMessage String?

  aiEnabled  Boolean @default(false)
  aiTone     String  @default("professional")
  aiLanguage String  @default("en")

  businessHoursOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  action   String
  entity   String
  entityId String?

  oldValues   Json?
  newValues   Json?
  description String?

  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([businessId])
  @@index([action])
  @@index([createdAt])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String?

  type    String
  title   String
  message String

  entityType String?
  entityId   String?

  isRead     Boolean  @default(false)
  readAt     DateTime?
  isArchived Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model ThemePreference {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme            String  @default("dark")
  sidebarCollapsed Boolean @default(false)
  accentColor      String  @default("blue")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== E-COMMERCE STORE ====================

model ECommerceStore {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  url         String?
  provider    String?
  config      Json?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ==================== POSTER TEMPLATES ====================

model PosterTemplate {
  id         String   @id @default(cuid())
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  name        String
  description String?
  category    String
  content     String
  variables   Json @default("[]")
  isSystem    Boolean @default(false)
  usageCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ==================== INVOICE ====================

model Invoice {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique
  subscriptionId String?

  amount   Int
  currency String @default("INR")
  status   String @default("pending")

  gateway     String?
  gatewayData Json?

  paidAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ==================== LEAD SCORE ====================

model LeadScore {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  score       Int @default(0)
  factors     Json[] @default([])
  category    String?
  engagementScore Int @default(0)
  recencyScore    Int @default(0)
  aiConfidence    Float?
  reasons         String[] @default([])
  aiModel         String?
  lastScoredAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([businessId, contactId])
  @@index([businessId])
  @@index([score])
}

// ==================== WHITE LABEL ====================

model WhiteLabel {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  brandName    String?
  logoUrl      String?
  faviconUrl   String?
  primaryColor String?
  customCss    String?
  customDomain String?

  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

// ==================== WEBHOOKS ====================

model Webhook {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  events     Json
  secret     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([isActive])
}

// ==================== API KEYS ====================

model ApiKey {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  key         String   @unique
  prefix      String?
  permissions Json
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([isActive])
}

// ==================== CHATBOT FLOWS ====================

model ChatbotFlow {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  trigger    String   @default("keyword")
  keywords   String[] @default([])
  triggerValue String?
  response   String
  aiEnabled  Boolean  @default(false)
  nodes      Json?
  edges      Json?
  flowData   Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([isActive])
}

// ==================== SCHEDULED MESSAGES ====================

model ScheduledMessage {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  phone       String
  content     String
  type        String   @default("text")
  mediaUrl    String?
  mediaType   String?
  templateName String?
  templateVars Json?
  templateLanguage String?
  timezone    String   @default("Asia/Kolkata")
  scheduledAt DateTime
  status      String   @default("pending")
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([scheduledAt])
}

// ==================== AUTO REPLY ====================

model AutoReply {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  keyword    String
  response   String
  matchType  String   @default("exact")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([isActive])
}
